{
  "manifest_version": 3,
  "name": "TexWaller AI Connector",
  "version": "0.1.0",
  "description": "Connect TexWaller to supported AI providers in a simple, guided way.",
  "homepage_url": "https://texwaller.com",
  "browser_specific_settings": {
    "gecko": {
      "id": "texwaller-ai-connector@texwaller.com",
      "strict_min_version": "121.0"
    }
  },
  "icons": {
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "https://texwaller.com/*",
    "https://www.texwaller.com/*",
    "https://auth.openai.com/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://texwaller.com/*",
        "https://www.texwaller.com/*",
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "scripts": ["src/background.js"],
    "type": "module"
  }
}
