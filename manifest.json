{
  "manifest_version": 3,
  "name": "TexWaller AI Connector",
  "version": "0.1.0",
  "description": "Connect TexWaller to supported AI providers in a simple, guided way.",
  "homepage_url": "https://texwaller.com",
  "icons": {
    /* "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",*/
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "clipboardWrite",
    "offscreen",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://auth.openai.com/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  }
}
