{
  "manifest_version": 3,
  "minimum_chrome_version": "121",
  "name": "TexWaller AI Connector",
  "version": "0.1.1",
  "description": "Connect TexWaller to supported AI providers in a simple, guided way.",
  "homepage_url": "https://texwaller.com",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://localhost/*",
    "https://texwaller.com/*",
    "https://www.texwaller.com/*",
    "https://auth.openai.com/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://texwaller.com/*",
        "https://www.texwaller.com/*",
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  }
}
